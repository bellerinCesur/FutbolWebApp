36827>>>>>Class cWebSessionManagerStandard is a cWebSessionManager
36828>>>>>    
36828>>>>>    Procedure Construct_Object
36830>>>>>        Handle hoObj
36830>>>>>        
36830>>>>>        Forward Send Construct_Object
36832>>>>>        
36832>>>>>        Set pbSessionCookieHttpOnly to True
36833>>>>>        
36833>>>>>        Property Handle phoUserDD 0      // Handle to the WebAppUser DDO
36834>>>>>        Property Handle phoSessionDD 0   // Handle to the WebAppSession DDO  
36835>>>>>        Property Handle phoCrypto 0      // Handle to the PasswordHasher
36836>>>>>        
36836>>>>>        Get CreateNamed (RefClass(cWebAppUserDataDictionary)) 'oUserDD' to hoObj
36837>>>>>        Set phoUserDD to hoObj
36838>>>>>        
36838>>>>>        Get CreateNamed (RefClass(cWebAppSessionDataDictionary)) 'oSessionDD' to hoObj
36839>>>>>        Set DDO_Server of hoObj to (phoUserDD(Self))
36840>>>>>        Set phoSessionDD to hoObj
36841>>>>>        
36841>>>>>        Property Handle phoCrypto 0   // Handle to the Cryptographer
36842>>>>>        Get CreateNamed (RefClass(cPasswordHasher)) 'oCrypto' to hoObj
36843>>>>>        Set phoCrypto to hoObj
36844>>>>>        
36844>>>>>        Property Boolean pbPasswordHashing True
36845>>>>>        
36845>>>>>        Property Boolean pbCreatingNewSession False
36846>>>>>        Property String psLoginName
36847>>>>>        Property String psUserName ""
36848>>>>>        Property Integer piUserRights 0
36849>>>>>    End_Procedure
36850>>>>>    
36850>>>>>    Procedure End_Construct_Object
36852>>>>>        Forward Send End_Construct_Object
36854>>>>>        
36854>>>>>        Handle hoCrypto
36854>>>>>        Integer iFieldLen
36854>>>>>        If (pbPasswordHashing(Self)) Begin
36856>>>>>            Get phoCrypto to hoCrypto
36857>>>>>            Get_Attribute DF_FIELD_LENGTH of (RefTable(WebAppUser)) (RefTable(WebAppUser.Password)) to iFieldLen
36860>>>>>            If (iFieldLen < (RequiredBufferSize(hoCrypto) + 3)) Begin
36862>>>>>                Error DFERR_PROGRAM "The password field of WebAppUser is not large enough (128)"
36863>>>>>>
36863>>>>>            End
36863>>>>>>
36863>>>>>        End
36863>>>>>>
36863>>>>>    End_Procedure
36864>>>>>    
36864>>>>>    Function CreateSession String sRemoteAddress Returns String
36866>>>>>        String sSessionKey
36866>>>>>        Integer iErr
36866>>>>>        Boolean bLogWebSession
36866>>>>>        Handle hoSessionDD       
36866>>>>>        Get phoSessionDD to hoSessionDD
36867>>>>>        
36867>>>>>        //  Get session key
36867>>>>>        Forward Get CreateSession sRemoteAddress to sSessionKey
36869>>>>>        
36869>>>>>        Get pbLogWebSession to bLogWebSession
36870>>>>>        If not bLogWebSession Begin
36872>>>>>            Function_Return sSessionKey        
36873>>>>>        End
36873>>>>>>
36873>>>>>
36873>>>>>        //  Store session
36873>>>>>        Send Clear of hoSessionDD
36874>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.SessionKey to sSessionKey
36875>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.RemoteAddress to sRemoteAddress
36876>>>>>        Set Field_Changed_Value of hoSessionDD Field WebAppSession.Active to "Y"
36877>>>>>        Get Request_Validate of hoSessionDD to iErr
36878>>>>>        If (iErr) Begin
36880>>>>>            // this should not happen. If it does its a programming error
36880>>>>>            Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36881>>>>>>
36881>>>>>            Function_Return ""
36882>>>>>        End
36882>>>>>>
36882>>>>>        Send Request_Save of hoSessionDD
36883>>>>>        If (Err) Begin
36885>>>>>            // this shouldn't happen, if it does likely a duplicate session key issue, even through request_save already gave an error we give another one to make tracking down easier
36885>>>>>            Error DFERR_PROGRAM C_$WebAppSessionSaveFailed
36886>>>>>>
36886>>>>>            Function_Return ""
36887>>>>>        End
36887>>>>>>
36887>>>>>       
36887>>>>>        Function_Return sSessionKey        
36888>>>>>    End_Function
36889>>>>>    
36889>>>>>    Function ValidateSession String sSessionKey Boolean bOptLoadWebApp Returns Boolean
36891>>>>>        DateTime dtLastAccess dtCurrent
36891>>>>>        TimeSpan tsDiff
36891>>>>>        Integer iErr iSessionTimeout iSpanMinutes
36891>>>>>        Boolean bResult bCreatingNewSession
36891>>>>>        Boolean bLogWebSession bLoadWebApp
36891>>>>>        Integer eLoginMode
36891>>>>>        String sTime
36891>>>>>        Handle hoSessionDD hoUserDD       
36891>>>>>        
36891>>>>>        Move False to bLoadWebApp
36892>>>>>        If (num_arguments >= 2) Begin
36894>>>>>            Move bOptLoadWebApp to bLoadWebApp
36895>>>>>        End
36895>>>>>>
36895>>>>>        
36895>>>>>        Get phoSessionDD to hoSessionDD
36896>>>>>        Get phoUserDD to hoUserDD
36897>>>>>        
36897>>>>>        Get pbLogWebSession to bLogWebSession
36898>>>>>        Get peLoginMode to eLoginMode
36899>>>>>        
36899>>>>>        // for this object, you can only disable logging if login completely is disabled
36899>>>>>        If (not(bLogWebSession) and (eLoginMode<>lmLoginNone)) Begin
36901>>>>>            Error DFERR_PROGRAM C_$WebSessionLoggingMustBeEnabled
36902>>>>>>
36902>>>>>            Function_Return False
36903>>>>>        End
36903>>>>>>
36903>>>>>
36903>>>>>        //  Clear session properties
36903>>>>>        Set psSessionKey to ""
36904>>>>>        Send UpdateSessionProperties True
36905>>>>>        
36905>>>>>        If not bLogWebSession Begin
36907>>>>>            Forward Get ValidateSession sSessionKey to bResult
36909>>>>>            Function_Return bResult
36910>>>>>        End        
36910>>>>>>
36910>>>>>        
36910>>>>>        Move False to bResult
36911>>>>>        Get piSessionTimeout to iSessionTimeout 
36912>>>>>        
36912>>>>>        //  Check if session exists
36912>>>>>        Send Clear of hoSessionDD
36913>>>>>        Move sSessionKey to WebAppSession.SessionKey
36914>>>>>        Send Find of hoSessionDD EQ Index.1
36915>>>>>            
36915>>>>>        If (Found) Begin
36917>>>>>            //  Calculate timespan between now and last access time
36917>>>>>            Move (CurrentDateTime()) to dtCurrent
36918>>>>>            Move WebAppSession.LastAccessDate to dtLastAccess
36919>>>>>            Get StringToTime of hoSessionDD dtLastAccess WebAppSession.LastAccessTime to dtLastAccess
36920>>>>>            Move (dtCurrent - dtLastAccess) to tsDiff
36921>>>>>            Move (SpanTotalMinutes(tsDiff)) to iSpanMinutes
36922>>>>>            
36922>>>>>            //  Check if session didn't time out
36922>>>>>            If (IsDateValid(dtLastAccess) and (iSessionTimeout <= 0 or (iSpanMinutes < iSessionTimeout)) and WebAppSession.Active = "Y") Begin
36924>>>>>                Forward Get ValidateSession sSessionKey to bResult
36926>>>>>                   
36926>>>>>                If (bResult) Begin
36928>>>>>                    //  Update session record
36928>>>>>                    Get TimeToString of hoSessionDD dtCurrent to sTime 
36929>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessDate to dtCurrent
36930>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.LastAccessTime to sTime
36931>>>>>                    Set Field_Changed_Value of hoSessionDD Field WebAppSession.UseCount to (WebAppSession.UseCount + 1)
36932>>>>>                    Get Request_Validate of hoSessionDD to iErr
36933>>>>>                    If (iErr) Begin
36935>>>>>                        // this should not happen. If it does its a programming error
36935>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
36936>>>>>>
36936>>>>>                        Function_Return False
36937>>>>>                    End
36937>>>>>>
36937>>>>>                    Send Request_Save of hoSessionDD
36938>>>>>                    
36938>>>>>                    //  Update user properties
36938>>>>>                    Send UpdateSessionProperties False
36939>>>>>                End
36939>>>>>>
36939>>>>>            End
36939>>>>>>
36939>>>>>            Else Begin
36940>>>>>                // Test the Creating New Session Flag to protect against infinite recursion....
36940>>>>>                Get pbCreatingNewSession to bCreatingNewSession
36941>>>>>                
36941>>>>>                If (not(bCreatingNewSession)) Begin
36943>>>>>                    If (not(bLoadWebApp)) Begin
36945>>>>>                        Move False to bResult   //  We can only continue immediately if we were loading the webapp, other operations are not allowed!
36946>>>>>                        Error DFERR_WEBAPP_SESSION_TIMEOUT "Your application session has timed out or is inactive, please login again."
36947>>>>>>
36947>>>>>                        Send NavigateRefresh of ghoWebApp          // refresh the WebApp at the client (triggers a login)
36948>>>>>                    End
36948>>>>>>
36948>>>>>                    Else Begin
36949>>>>>                        Set pbCreatingNewSession to True                    
36950>>>>>                        Get RecreateSession of ghoWebApp to bResult 
36951>>>>>                        Set pbCreatingNewSession to False                        
36952>>>>>                    End
36952>>>>>>
36952>>>>>                End
36952>>>>>>
36952>>>>>            End
36952>>>>>>
36952>>>>>        End
36952>>>>>>
36952>>>>>        Else Begin
36953>>>>>            Error DFERR_WEBAPP_BAD_SESSION_KEY "Session key not known (reload page to recreate session)"
36954>>>>>>
36954>>>>>        End
36954>>>>>>
36954>>>>>        
36954>>>>>        Function_Return bResult
36955>>>>>    End_Function
36956>>>>>    
36956>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36958>>>>>        If (not(pbPasswordHashing(Self))) Begin
36960>>>>>            Move sPassword to sHash
36961>>>>>            Function_Return True
36962>>>>>        End
36962>>>>>>
36962>>>>>        
36962>>>>>        If (not(CreatePasswordHash(phoCrypto(Self), sPassword, &sHash))) Begin
36964>>>>>            Function_Return False
36965>>>>>        End
36965>>>>>>
36965>>>>>        Move ("V1$" + sHash) to sHash
36966>>>>>        Function_Return True
36967>>>>>    End_Function
36968>>>>>    
36968>>>>>    Function VerifyPasswordHash String sUserPassword String sEnteredPassword Boolean ByRef bShouldUpgrade Returns Boolean
36970>>>>>        If (not(pbPasswordHashing(Self))) Begin
36972>>>>>            Move False to bShouldUpgrade
36973>>>>>            Function_Return (sUserPassword = sEnteredPassword)
36974>>>>>        End
36974>>>>>>
36974>>>>>        
36974>>>>>        String sVersion
36974>>>>>        Move (Left(sUserPassword, 3)) to sVersion
36975>>>>>        If (sVersion = "V1$") Begin
36977>>>>>            If (num_arguments > 2) Move False to bShouldUpgrade
36980>>>>>            Function_Return (VerifyPasswordHash(phoCrypto(Self), sEnteredPassword, Right(sUserPassword, Length(sUserPassword) - 3)))
36981>>>>>        End
36981>>>>>>
36981>>>>>        Else Begin
36982>>>>>            If (num_arguments > 2) Move True to bShouldUpgrade
36985>>>>>            Function_Return False
36986>>>>>        End
36986>>>>>>
36986>>>>>    End_Function

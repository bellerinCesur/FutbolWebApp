38421>>>
38421>>>            Case (NavigateData.eNavigateType = nfFromParent)
38424>>>                // If from parent, this is a constrained drill down.
38424>>>                Case Break
38425>>>
38425>>>            Case (NavigateData.eNavigateType = nfFromChild)
38428>>>                // If from child, this is a probably a parent Zoom from a Zoom.
38428>>>                Case Break
38429>>>
38429>>>            Case Else // must be nfUndefined
38429>>>
38429>>>        Case End
38429>>>
38429>>>        Send SetActionButtons
38430>>>

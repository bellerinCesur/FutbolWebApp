36691>>>>>>>                Error 8710 "Invalid algorithm selected."
36692>>>>>>>>
36692>>>>>>>                Function_Return False
36693>>>>>>>        Case End
36693>>>>>>>        
36693>>>>>>>        String sSalt
36693>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36694>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return False
36697>>>>>>>        Get Base64EncodeArr ucaHash to sHash
36698>>>>>>>        If (not(SizeOfString(sHash))) Function_Return False
36701>>>>>>>        
36701>>>>>>>        If (bRequireTimeCost) Begin
36703>>>>>>>            Move (SFormat("%1$%2$%3$%4",            ;                            String(uiAlgo),         ;                            sSalt,                  ;                            String(uiOptTimeCost),  ;                            sHash)) to sHash
36704>>>>>>>        End
36704>>>>>>>>
36704>>>>>>>        Else Begin
36705>>>>>>>            Move (SFormat("%1$%2$%3",               ;                            String(uiAlgo),         ;                            sSalt,                  ;                            sHash)) to sHash
36706>>>>>>>        End
36706>>>>>>>>
36706>>>>>>>        
36706>>>>>>>        Function_Return bOk
36707>>>>>>>    End_Function
36708>>>>>>>    
36708>>>>>>>    Function CreatePasswordHashEx UInteger uiAlgo UInteger uiSaltSize String sPassword String ByRef sHash UInteger uiOptTimeCost Returns Boolean
36710>>>>>>>        UChar[] ucaSalt
36711>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36712>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36715>>>>>>>        
36715>>>>>>>        If (num_arguments > 4) Begin
36717>>>>>>>            Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash, uiOptTimeCost))
36718>>>>>>>        End
36718>>>>>>>>
36718>>>>>>>        Function_Return (CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sHash))
36719>>>>>>>    End_Function
36720>>>>>>>    
36720>>>>>>>    Function VerifyPasswordHash String sPassword String sHash Returns Boolean
36722>>>>>>>        Boolean bRequiresTimeCost
36722>>>>>>>        UInteger uiAlgo uiTimeCost
36722>>>>>>>        Integer iBegin iEnd
36722>>>>>>>        String sSalt
36722>>>>>>>        
36722>>>>>>>        Move 1 to iBegin
36723>>>>>>>        
36723>>>>>>>        // Parse Algo
36723>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36724>>>>>>>        If (not(iEnd)) Function_Return False
36727>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiAlgo
36728>>>>>>>        
36728>>>>>>>        // Parse Salt
36728>>>>>>>        Move (iEnd + 1) to iBegin
36729>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36730>>>>>>>        If (not(iEnd)) Function_Return False
36733>>>>>>>        Move (Mid(sHash, iEnd - iBegin, iBegin)) to sSalt
36734>>>>>>>        
36734>>>>>>>        Case Begin
36734>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36736>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36739>>>>>>>                Move True to bRequiresTimeCost
36740>>>>>>>                Case Break
36741>>>>>>>            Case Else
36741>>>>>>>                Error 8710 "Invalid algorithm selected."
36742>>>>>>>>
36742>>>>>>>                Function_Return False
36743>>>>>>>        Case End
36743>>>>>>>        
36743>>>>>>>        // Parse optional timecost
36743>>>>>>>        If (bRequiresTimeCost) Begin
36745>>>>>>>            Move (iEnd + 1) to iBegin
36746>>>>>>>            Move (Pos("$", sHash, iBegin)) to iEnd
36747>>>>>>>            If (not(iEnd)) Function_Return False
36750>>>>>>>            Move (Mid(sHash, iEnd - iBegin, iBegin)) to uiTimeCost
36751>>>>>>>        End
36751>>>>>>>>
36751>>>>>>>        
36751>>>>>>>        // Parse rest hash
36751>>>>>>>        Move (iEnd + 1) to iBegin
36752>>>>>>>        Move (Pos("$", sHash, iBegin)) to iEnd
36753>>>>>>>        If (iEnd) Function_Return False // inverse check if there are any other errors.
36756>>>>>>>        
36756>>>>>>>        // Base64Decode
36756>>>>>>>        UChar[] ucaSalt
36757>>>>>>>        Get Base64DecodeArr sSalt to ucaSalt
36758>>>>>>>        If (not(SizeOfArray(ucaSalt))) Function_Return False
36761>>>>>>>        
36761>>>>>>>        // Create new hash
36761>>>>>>>        String sNewHash
36761>>>>>>>        If (bRequiresTimeCost) Begin
36763>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash, uiTimeCost))) Begin
36765>>>>>>>                Function_Return False 
36766>>>>>>>            End
36766>>>>>>>>
36766>>>>>>>        End
36766>>>>>>>>
36766>>>>>>>        Else Begin
36767>>>>>>>            If (not(CreatePasswordHashExWithSalt(Self, uiAlgo, ucaSalt, sPassword, &sNewHash))) Begin
36769>>>>>>>                Function_Return False 
36770>>>>>>>            End
36770>>>>>>>>
36770>>>>>>>        End
36770>>>>>>>>
36770>>>>>>>        Function_Return (sNewHash = sHash)
36771>>>>>>>    End_Function
36772>>>>>>>    
36772>>>>>>>    Function RequiredBufferSizeEx UInteger uiAlgo UInteger uiSaltSize UInteger uiOptTimeCost Returns UBigInt
36774>>>>>>>        Boolean bRequireTimeCost
36774>>>>>>>        UBigInt ullSize
36774>>>>>>>        UChar[] ucaSalt
36775>>>>>>>        String sSalt
36775>>>>>>>        
36775>>>>>>>        Get RandomBuffer uiSaltSize to ucaSalt
36776>>>>>>>        Get Base64EncodeArr ucaSalt to sSalt
36777>>>>>>>        If (not(SizeOfString(sSalt))) Function_Return 0
36780>>>>>>>        
36780>>>>>>>        Case Begin
36780>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36782>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA256" to ullSize
36783>>>>>>>                Move True to bRequireTimeCost
36784>>>>>>>                Case Break
36785>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36788>>>>>>>                Get CNG_PBKDF2_HMAC_BufferSize "SHA512" to ullSize
36789>>>>>>>                Move True to bRequireTimeCost
36790>>>>>>>                Case Break
36791>>>>>>>            Case Else
36791>>>>>>>                Error 8710 "Invalid algorithm selected."
36792>>>>>>>>
36792>>>>>>>                Function_Return 0
36793>>>>>>>        Case End
36793>>>>>>>        
36793>>>>>>>        // calculate base64 in a non-floating-manner
36793>>>>>>>        Move (((ullSize + 3 -1) / 3) * 4) to ullSize
36794>>>>>>>        
36794>>>>>>>        Move (ullSize + SizeOfString(String(uiAlgo))) to ullSize
36795>>>>>>>        Move (ullSize + SizeOfString(sSalt)) to ullSize
36796>>>>>>>        If (bRequireTimeCost) Begin
36798>>>>>>>            Move (ullSize + SizeOfString(String(uiOptTimeCost))) to ullSize
36799>>>>>>>            Move (ullSize + 3 /*$*/) to ullSize
36800>>>>>>>        End
36800>>>>>>>>
36800>>>>>>>        Else Begin
36801>>>>>>>            Move (ullSize + 2 /*$*/) to ullSize
36802>>>>>>>        End
36802>>>>>>>>
36802>>>>>>>        
36802>>>>>>>        Function_Return ullSize
36803>>>>>>>    End_Function
36804>>>>>>>End_Class
36805>>>>>>>
36805>>>>>>>Class cPasswordHasher is a cObject
36806>>>>>>>    
36806>>>>>>>    Import_Class_Protocol cPasswordHasher_Mixin
36807>>>>>>>    
36807>>>>>>>    Procedure Construct_Object
36809>>>>>>>        Forward Send Construct_Object
36811>>>>>>>        
36811>>>>>>>        Property UInteger   peAlgorithm         C_PWH_PBKDF2_HMAC_SHA_512 
36812>>>>>>>        Property UInteger   puiSaltSize         16
36813>>>>>>>        
36813>>>>>>>        Property UInteger   puiOptTimeCost      420000
36814>>>>>>>    End_Procedure
36815>>>>>>>    
36815>>>>>>>    Function CreatePasswordHash String sPassword String ByRef sHash Returns Boolean
36817>>>>>>>        Boolean bOk
36817>>>>>>>        UInteger uiAlgo
36817>>>>>>>        Get peAlgorithm to uiAlgo
36818>>>>>>>        
36818>>>>>>>        Case Begin
36818>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36820>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36823>>>>>>>                Get CreatePasswordHashEx uiAlgo (puiSaltSize(Self)) sPassword (&sHash) (puiOptTimeCost(Self)) to bOk
36824>>>>>>>                Case Break
36825>>>>>>>            Case Else
36825>>>>>>>                Error 8710 "Invalid algorithm selected."
36826>>>>>>>>
36826>>>>>>>                Function_Return False
36827>>>>>>>        Case End
36827>>>>>>>        
36827>>>>>>>        Function_Return bOk
36828>>>>>>>    End_Function
36829>>>>>>>    
36829>>>>>>>    Function RequiredBufferSize Returns UBigInt
36831>>>>>>>        UBigInt ullSize
36831>>>>>>>        UInteger uiAlgo
36831>>>>>>>        Get peAlgorithm to uiAlgo
36832>>>>>>>        
36832>>>>>>>        Case Begin
36832>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_256)
36834>>>>>>>            Case (uiAlgo = C_PWH_PBKDF2_HMAC_SHA_512)
36837>>>>>>>                Get RequiredBufferSizeEx uiAlgo (puiSaltSize(Self)) (puiOptTimeCost(Self)) to ullSize
36838>>>>>>>                Case Break
36839>>>>>>>            Case Else
36839>>>>>>>                Error 8710 "Invalid algorithm selected."
36840>>>>>>>>
36840>>>>>>>                Function_Return 0
36841>>>>>>>        Case End
36841>>>>>>>        
36841>>>>>>>        Function_Return ullSize
36842>>>>>>>    End_Function
36843>>>>>>>
36843>>>>>>>End_Class

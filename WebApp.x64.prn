38387>>>    Procedure SetActionButtons
38390>>>        tWebNavigateData NavigateData
38390>>>        tWebNavigateData NavigateData
38390>>>        Boolean bHasRecord
38390>>>        Handle hoDD
38390>>>
38390>>>        Get Server to hoDD
38391>>>        Get GetNavigateData to NavigateData
38392>>>        Get HasRecord of hoDD to bHasRecord
38393>>>
38393>>>        // let's hide all buttons and then Show the ones we want
38393>>>        WebSet pbRender of oEditBtn to False
38394>>>        WebSet pbRender of oSaveBtn to False
38395>>>        WebSet pbRender of oCancelChangesBtn to False
38396>>>        WebSet pbRender of oDeleteBtn to False
38397>>>
38397>>>        If (NavigateData.bReadOnly) Begin
38399>>>            WebSet pbRender of oEditBtn to True
38400>>>        End
38400>>>>
38400>>>        Else Begin
38401>>>            WebSet pbRender of oSaveBtn to True
38402>>>            WebSet pbRender of oCancelChangesBtn to True
38403>>>            WebSet pbRender of oDeleteBtn to bHasRecord
38404>>>        End
38404>>>>
38404>>>    End_Procedure

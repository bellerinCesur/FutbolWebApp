37759>>>    Procedure SetActionButtons
37762>>>        tWebNavigateData NavigateData
37762>>>        tWebNavigateData NavigateData
37762>>>        Boolean bHasRecord
37762>>>        Handle hoDD
37762>>>
37762>>>        Get Server to hoDD
37763>>>        Get GetNavigateData to NavigateData
37764>>>        Get HasRecord of hoDD to bHasRecord
37765>>>
37765>>>        // let's hide all buttons and then Show the ones we want
37765>>>        WebSet pbRender of oEditBtn to False
37766>>>        WebSet pbRender of oSaveBtn to False
37767>>>        WebSet pbRender of oCancelChangesBtn to False
37768>>>        WebSet pbRender of oDeleteBtn to False
37769>>>
37769>>>        If (NavigateData.bReadOnly) Begin
37771>>>            WebSet pbRender of oEditBtn to True
37772>>>        End
37772>>>>
37772>>>        Else Begin
37773>>>            WebSet pbRender of oSaveBtn to True
37774>>>            WebSet pbRender of oCancelChangesBtn to True
37775>>>            WebSet pbRender of oDeleteBtn to bHasRecord
37776>>>        End
37776>>>>
37776>>>    End_Procedure

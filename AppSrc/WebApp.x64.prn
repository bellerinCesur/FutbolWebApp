37593>>>    Procedure OnNavigateForward tWebNavigateData NavigateData Integer hoInvokingView Integer hoInvokingObject
37596>>>        WebSet pbRender of oNewButton to True
37597>>>        WebSet pbRender of oDetailButton to True
37598>>>
37598>>>        Case Begin
37598>>>            Case (NavigateData.eNavigateType = nfFromParent)
37600>>>                // If from parent, this is a constrained drill down
37600>>>                Case Break
37601>>>
37601>>>            Case (NavigateData.eNavigateType = nfFromChild)
37604>>>                // If from child, this is a probably a parent lookup from a Zoom
37604>>>                Case Break
37605>>>
37605>>>            Case (NavigateData.eNavigateType = nfFromMain)
37608>>>                // If from main, this is a probably a main-file lookup from a Zoom
37608>>>                WebSet pbRender of oDetailButton to False
37609>>>                Case Break
37610>>>
37610>>>            Case Else // must be nfUndefined
37610>>>                // This may be the start of a drilldown query or this may be used for some kind of custom query.
37610>>>
37610>>>        Case End
37610>>>
37610>>>    End_Procedure

37793>>>            Case (NavigateData.eNavigateType = nfFromParent)
37796>>>                // If from parent, this is a constrained drill down.
37796>>>                Case Break
37797>>>
37797>>>            Case (NavigateData.eNavigateType = nfFromChild)
37800>>>                // If from child, this is a probably a parent Zoom from a Zoom.
37800>>>                Case Break
37801>>>
37801>>>            Case Else // must be nfUndefined
37801>>>
37801>>>        Case End
37801>>>
37801>>>        Send SetActionButtons

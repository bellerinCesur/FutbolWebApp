36530>>>>>>>    //
36530>>>>>>>    //  Converts the given time to an string that can be saved in the database.
36530>>>>>>>    //
36530>>>>>>>    //  Params:
36530>>>>>>>    //      dtTime  Time to convert
36530>>>>>>>    //  Returns:
36530>>>>>>>    //      String with "HH:MM:SS" format
36530>>>>>>>    //
36530>>>>>>>    Function TimeToString DateTime dtTime Returns String
36532>>>>>>>        String sHours sMinutes sSeconds
36532>>>>>>>        
36532>>>>>>>        //  Extract parts
36532>>>>>>>        Move (String(DateGetHour(dtTime))) to sHours
36533>>>>>>>        Move (String(DateGetMinute(dtTime))) to sMinutes
36534>>>>>>>        Move (String(DateGetSecond(dtTime))) to sSeconds
36535>>>>>>>        
36535>>>>>>>        //  Fill out with 0
36535>>>>>>>        If (Length(sHours) = 1) ;            Move ("0" + sHours) to sHours
36538>>>>>>>        If (Length(sMinutes) = 1) ;            Move ("0" + sMinutes) to sMinutes
36541>>>>>>>        If (Length(sSeconds) = 1) ;            Move ("0" + sSeconds) to sSeconds
36544>>>>>>>        
36544>>>>>>>        Function_Return (sHours + ":" + sMinutes + ":" + sSeconds)
36545>>>>>>>    End_Function
36546>>>>>>>    
36546>>>>>>>    //
36546>>>>>>>    //  Sets the time of the datetime variable to the time in the string.
36546>>>>>>>    //
36546>>>>>>>    //  Params:
36546>>>>>>>    //      dtTime  Datetime variable to add time to
36546>>>>>>>    //      sTimeString String with time in the format "HH:MM:SS"
36546>>>>>>>    //  Returns:
36546>>>>>>>    //      dtDateTime with the loaded time
36546>>>>>>>    //
36546>>>>>>>    Function StringToTime DateTime dtTime String sTimeString Returns DateTime
36548>>>>>>>        String sHours sMinutes sSeconds
36548>>>>>>>        
36548>>>>>>>        //  Extract parts
36548>>>>>>>        Move (Mid(sTimeString, 2, 1)) to sHours
36549>>>>>>>        Move (Mid(sTimeString, 2, 4)) to sMinutes
36550>>>>>>>        Move (Mid(sTimeString, 2, 7)) to sSeconds
36551>>>>>>>        
36551>>>>>>>        //  Set to DateTime
36551>>>>>>>        Move (DateSetHour(dtTime, (Integer(sHours)))) to dtTime
36552>>>>>>>        Move (DateSetMinute(dtTime, (Integer(sMinutes)))) to dtTime
36553>>>>>>>        Move (DateSetSecond(dtTime, (Integer(sSeconds)))) to dtTime
36554>>>>>>>        
36554>>>>>>>        Function_Return dtTime
36555>>>>>>>    End_Function

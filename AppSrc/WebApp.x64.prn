37004>>>>>    Function UserRegister String sLoginName String sPassword Returns Boolean
37006>>>>>        Handle hoUserDD
37006>>>>>        Integer iErr
37006>>>>>        Get phoUserDD to hoUserDD
37007>>>>>        
37007>>>>>        //  Find the user
37007>>>>>        Send Clear of hoUserDD
37008>>>>>        Move sLoginName to WebAppUser.LoginName
37009>>>>>        Send Find of hoUserDD EQ Index.1
37010>>>>>        If (Found) Begin
37012>>>>>            Send Clear of hoUserDD
37013>>>>>            Function_Return False
37014>>>>>        End
37014>>>>>>
37014>>>>>        
37014>>>>>        Send Clear of hoUserDD
37015>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.FullName to sLoginName
37016>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.LoginName to sLoginName
37017>>>>>        If (not(CreatePasswordHash(Self, Trim(sPassword), &sPassword))) Begin
37019>>>>>            Send Clear of hoUserDD
37020>>>>>            Function_Return False
37021>>>>>        End
37021>>>>>>
37021>>>>>        Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37022>>>>>        Get Request_Validate of hoUserDD to iErr
37023>>>>>        If (iErr) Begin
37025>>>>>            Send Clear of hoUserDD
37026>>>>>            Function_Return False
37027>>>>>        End
37027>>>>>>
37027>>>>>        
37027>>>>>        Send Request_Save of hoUserDD
37028>>>>>        Function_Return (not(Err))
37029>>>>>    End_Function
37030>>>>>    
37030>>>>>    Function UserLogin String sLoginName String sPassword Returns Boolean
37032>>>>>        String sSessionKey sUserPassword
37032>>>>>        Handle hoSessionDD hoUserDD
37032>>>>>        Boolean bMatch bUpgrade
37032>>>>>        
37032>>>>>        Get phoSessionDD to hoSessionDD
37033>>>>>        Get phoUserDD to hoUserDD
37034>>>>>        Integer iErr eLoginMode
37034>>>>>        
37034>>>>>        // Refind session record
37034>>>>>        Get psSessionKey to sSessionKey
37035>>>>>        Send Clear of hoSessionDD
37036>>>>>        Move sSessionKey to WebAppSession.SessionKey
37037>>>>>        Send Find of hoSessionDD EQ Index.1
37038>>>>>        
37038>>>>>        If (Found and WebAppSession.SessionKey = sSessionKey) Begin
37040>>>>>            Get peLoginMode to eLoginMode
37041>>>>>            
37041>>>>>            //  Find the user
37041>>>>>            Move sLoginName to WebAppUser.LoginName
37042>>>>>            Send Find of hoUserDD EQ Index.1
37043>>>>>            
37043>>>>>            // Check username and password
37043>>>>>            If (Found and (Lowercase(sLoginName) = Lowercase(Trim(WebAppUser.LoginName)))) Begin
37045>>>>>                Get Field_Current_Value of hoUserDD Field WebAppUser.Password to sUserPassword
37046>>>>>                Get VerifyPasswordHash (Trim(sUserPassword)) (Trim(sPassword)) (&bUpgrade) to bMatch
37047>>>>>                
37047>>>>>                If (bMatch) Begin
37049>>>>>                    // Store the login
37049>>>>>                    If (bUpgrade) Begin
37051>>>>>                        Get CreatePasswordHash (Trim(sPassword)) (&sPassword) to bUpgrade
37052>>>>>                        If (bUpgrade) Set Field_Changed_Value of hoUserDD Field WebAppUser.Password to sPassword
37055>>>>>                    End
37055>>>>>>
37055>>>>>                    Set Field_Changed_Value of hoUserDD Field WebAppUser.LastLogin to (CurrentDateTime())
37056>>>>>                    Get Request_Validate of hoSessionDD to iErr
37057>>>>>                    If (iErr) Begin
37059>>>>>                        // this should not happen. If it does its a programming error
37059>>>>>                        Error DFERR_PROGRAM C_$WebAppSessionValidateFailed
37060>>>>>>
37060>>>>>                        Function_Return False
37061>>>>>                    End
37061>>>>>>
37061>>>>>                    
37061>>>>>                    Send Request_Save of hoSessionDD
37062>>>>>                    
37062>>>>>                    // Update session properties
37062>>>>>                    Send UpdateSessionProperties False
37063>>>>>                    Send NotifyChangeRights
37064>>>>>                    Function_Return True
37065>>>>>                End
37065>>>>>>
37065>>>>>                Else Begin
37066>>>>>                    //  We should rely directly on this buffer elsewhere but just be sure
37066>>>>>                    Send Clear of hoUserDD
37067>>>>>                End
37067>>>>>>
37067>>>>>            End
37067>>>>>>
37067>>>>>            Else Begin
37068>>>>>                // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37068>>>>>                Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37069>>>>>            End
37069>>>>>>
37069>>>>>        End
37069>>>>>>
37069>>>>>        Else Begin
37070>>>>>            // This is added to delay latency to avoid hackers finding out whether the user exists or not.
37070>>>>>            Get CreatePasswordHash "This is to delay the response latency." (&sPassword) to iErr
37071>>>>>        End
37071>>>>>>
37071>>>>>          
37071>>>>>        Function_Return False
37072>>>>>    End_Function
